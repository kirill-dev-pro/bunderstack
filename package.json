{
  "name": "bunderstack-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "test": "bun test --cwd packages/bunderstack && bun test --cwd packages/bunderstack-query",
    "dev": "bun run --cwd examples/standalone dev",
    "dev:standalone": "bun run --cwd examples/standalone dev",
    "dev:nextjs": "bun run --cwd examples/nextjs dev",
    "dev:tanstack": "bun run --cwd examples/tanstack-start dev",
    "dev:kanban": "bun run --cwd examples/kanban-solid-1.9 dev",
    "dev:kanban-tanstack": "bun run --cwd examples/kanban-tanstack dev",
    "db:push": "bun run --cwd examples/standalone db:push && bun run --cwd examples/tanstack-start db:push && bun run --cwd examples/nextjs db:push",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "fix": "bun run lint && bun run format"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^7.0.1-rc"
  }
}
